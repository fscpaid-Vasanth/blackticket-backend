# ============================================================
# BlackTicket MVP Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real credentials.
# Local development works out-of-the-box with the Docker
# postgres/redis credentials already pre-filled below.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL (matches docker-compose.yml) ─────────────────
DATABASE_URL="postgresql://blackticket_admin:admin_secure_pass_99@localhost:5432/blackticket_mvp_db"

# ── Redis (matches docker-compose.yml) ──────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Secrets (change both in production!) ────────────────
JWT_SECRET=blackticket_secret_jwt_key_mvp_99
JWT_REFRESH_SECRET=blackticket_refresh_jwt_key_mvp_99
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Razorpay (get from https://dashboard.razorpay.com) ──────
# Use rzp_test_* keys during development.
# Switch to rzp_live_* in production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── AWS S3 (for ticket PDF/image storage) ───────────────────
# Get from AWS Console → IAM → Create user → programmatic access
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=blackticket-mvp-tickets

# ── Sentry (optional — for error monitoring in production) ───
# Leave blank to disable Sentry locally
SENTRY_DSN=
